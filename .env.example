# ============================================================
# Nifty50 Options Scalper — Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env to Git — it is already in .gitignore
#   4. On your GCP server, set these as system environment
#      variables or use a secrets manager (GCP Secret Manager)
# ============================================================

# ---- MASTER ENCRYPTION KEY (for encrypting subscriber API keys at rest) ----
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# ---- TELEGRAM BOT ----
# Create a bot via @BotFather on Telegram, get the token
TELEGRAM_BOT_TOKEN=1234567890:ABCDefGhIJKlmNoPQRsTUVwxyZ
# Your personal Telegram chat_id (send /start to @userinfobot to find yours)
TELEGRAM_ADMIN_CHAT_ID=123456789
# Subscriber broadcast channel ID (create a Telegram channel, add bot as admin)
TELEGRAM_CHANNEL_ID=-100123456789

# ---- INDIA VIX DATA ----
# NSE VIX is scraped from the public NSE endpoint — no key required
# But if you use a paid data provider, put its key here
DATA_PROVIDER_API_KEY=REPLACE_IF_USING_PAID_DATA_PROVIDER

# ---- ZERODHA KITE CONNECT (Your own/admin account for VIX fetching) ----
# Obtain from https://kite.trade after purchasing developer subscription
ZERODHA_ADMIN_API_KEY=your_zerodha_api_key_here
ZERODHA_ADMIN_API_SECRET=your_zerodha_api_secret_here
# This token refreshes daily — the live_main.py handles this automatically
ZERODHA_ADMIN_ACCESS_TOKEN=leave_blank_auto_generated_at_runtime

# ---- ANGEL ONE SMARTAPI (Your own/admin account) ----
# Obtain from https://smartapi.angelbroking.com
ANGEL_ADMIN_API_KEY=your_angel_api_key_here
ANGEL_ADMIN_CLIENT_ID=your_angel_client_id_here
ANGEL_ADMIN_PASSWORD=your_angel_mpin_here
# TOTP secret — scan the QR code at Angel SmartAPI and extract the base32 secret
ANGEL_ADMIN_TOTP_SECRET=your_base32_totp_secret_here

# ---- SERVER CONFIG ----
# Set to "production" on GCP, "development" on local machine
APP_ENV=development
# Path where the encrypted subscriber config JSON is stored
SUBSCRIBER_CONFIG_PATH=/home/claude/nifty_scalper/data/subscribers.enc.json
# Path for SQLite trade log database
TRADE_LOG_DB_PATH=/home/claude/nifty_scalper/data/trade_log.db
# Path for application log files
LOG_DIR=/home/claude/nifty_scalper/logs
